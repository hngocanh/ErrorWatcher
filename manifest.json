{
    "manifest_version": 3,
    "name": "Error Watcher",
    "version": "1.0.2",
    "description": "Monitors web pages for JavaScript errors, console warnings, and network failures.",
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    },
    "permissions": [
        "debugger",
        "notifications",
        "tabs",
        "storage",
        "alarms"
    ],
    "background": {
        "service_worker": "src/background.ts",
        "type": "module"
    },
    "action": {
        "default_popup": "src/popup.html",
        "default_icon": {
            "16": "public/icons/icon16.png",
            "48": "public/icons/icon48.png",
            "128": "public/icons/icon128.png"
        }
    },
    "icons": {
        "16": "public/icons/icon16.png",
        "48": "public/icons/icon48.png",
        "128": "public/icons/icon128.png"
    },
    "web_accessible_resources": [
        {
            "resources": [
                "src/detail.html"
            ],
            "matches": [
                "<all_urls>"
            ]
        }
    ]
}